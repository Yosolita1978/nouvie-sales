generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// USER MODEL - Admin Authentication
// ============================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed with bcryptjs
  name      String
  role      String   @default("admin") // admin, manager, viewer
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ============================================
// CUSTOMER MODEL - Client Information
// ============================================
model Customer {
  id        String   @id @default(uuid())
  documentType String  @default("cedula") // "cedula", "nit", "cedula_extranjeria"
  cedula    String?  @unique // Optional document number. NULL = informal sale (no factura). Postgres treats NULLs as distinct, so many cédula-less customers are allowed.
  name      String
  email     String?
  phone     String
  address   String?
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  orders    Order[]

  @@index([cedula])
  @@index([name])
  @@index([active])
  @@map("customers")
}

// ============================================
// PRODUCT MODEL - Product Catalog
// ============================================
model Product {
  id        String   @id @default(uuid())
  name      String
  type      String   // "simple" or "variable"
  category  String   // e.g., "Electronics", "Clothing", etc.
  unit      String   // e.g., "unit", "kg", "liter"
  price     Decimal  @db.Decimal(10, 2)
  stock     Int      @default(0)
  minStock  Int      @default(5) // Alert threshold
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  orderItems OrderItem[]

  @@index([name])
  @@index([category])
  @@index([active])
  @@map("products")
}

// ============================================
// ORDER MODEL - Order Header
// ============================================
model Order {
  id            String    @id @default(uuid())
  orderNumber   String    @unique // e.g., "ORD-2025-0001"
  customerId    String
  orderDate     DateTime  @default(now())
  
  // Amounts
  subtotal      Decimal   @db.Decimal(10, 2)
  tax           Decimal   @db.Decimal(10, 2)
  discount      Decimal   @default(0) @db.Decimal(10, 2)
  total         Decimal   @db.Decimal(10, 2)
  
  // Payment
  paymentMethod String    // "cash", "transfer", "card", "credit"
  paymentStatus String    @default("pending") // "pending", "partial", "paid"
  paymentDate   DateTime?
  
  // Shipping
  shippingStatus String   @default("preparing") // "preparing", "shipped", "delivered"
  shippingDate   DateTime?
  deliveryDate   DateTime?
  
  // Order type
  orderType     String    @default("normal") // "normal" | "promomix"

  // Additional
  invoiceNumber String?   @unique
  notes         String?   @db.Text
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  customer      Customer  @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items         OrderItem[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([orderDate])
  @@index([paymentStatus])
  @@index([shippingStatus])
  @@index([orderType])
  @@map("orders")
}

// ============================================
// ORDER ITEM MODEL - Products in Order
// ============================================
model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  // Relationships
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================
// EXCHANGE RATE - Updated monthly
// ============================================
model ExchangeRate {
  id        String   @id @default(uuid())
  currency  String   @unique // e.g., "USD"
  rate      Decimal  @db.Decimal(10, 2) // COP per 1 unit of currency
  updatedAt DateTime @updatedAt

  @@map("exchange_rates")
}

// ============================================
// HISTORIC SALE - Isolated import of the old ventas CSV
// ============================================
// Deliberately DECOUPLED from customers/products/orders: no foreign keys,
// client and product references are plain strings. This keeps the live
// tables pristine (no duplicates/conflicts) while the reports page reads
// from here and only read-cross-references live orders.
model HistoricSale {
  id            String   @id @default(uuid())

  // Source traceability + idempotency (re-import upserts by rowNumber)
  rowNumber     Int      @unique // 1-based line in the source CSV
  rawDate       String   // original FECHA text, e.g. "abril 18"
  rawAmount     String?  // original TOTAL RECAUDO text, before normalization
  rawProduct    String   @db.Text // original PEDIDO free text

  // Normalized fields
  saleDate      DateTime // inferred full date
  year          Int      // inferred year (2024 / 2025 / 2026)
  amount        Decimal  @db.Decimal(12, 2) // normalized COP total

  // Client (no FK to customers — matched later, read-only)
  clientName    String
  cedula        String?
  email         String?
  phone         String?
  city          String?
  address       String?

  // Extra sheet columns kept for reference
  paymentStatus String?  // ESTADO DE PAGO
  logistica     String?  // LOGÍSTICA
  observacion   String?  @db.Text

  // Parser notes: anything guessed (inferred year, ambiguous money format,
  // unmapped product). Stored as JSON string so nothing is silently wrong.
  parseFlags    String?  @db.Text

  createdAt     DateTime @default(now())

  items         HistoricSaleItem[]

  @@index([year])
  @@index([clientName])
  @@index([cedula])
  @@index([saleDate])
  @@map("historic_sales")
}

// ============================================
// HISTORIC PRODUCT MAPPING - Manual overmap of "UNMAPPED" items
// ============================================
// Lets the admin assign a canonical product to an unmapped historic item from
// the platform (no code). Keyed by the exact stored item name ("UNMAPPED: ...").
// Separate table so it survives re-imports of historic_sales.
model HistoricProductMapping {
  id           String   @id @default(uuid())
  unmappedName String   @unique // the exact HistoricSaleItem.productName, e.g. "UNMAPPED: kit melon"
  productName  String   // canonical product to count it as
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("historic_product_mappings")
}

// ============================================
// HISTORIC SALE ITEM - Parsed product lines
// ============================================
// productName is the CANONICAL DB product name (or "UNMAPPED: <text>" when the
// parser can't match). No FK to Product on purpose — kept as a decoupled string.
model HistoricSaleItem {
  id             String       @id @default(uuid())
  historicSaleId String
  productName    String       // canonical name, or "UNMAPPED: ..."
  quantity       Int
  fromKit        Boolean      @default(false) // expanded out of a "kit de N"
  rawText        String?      // the fragment this line was parsed from

  historicSale   HistoricSale @relation(fields: [historicSaleId], references: [id], onDelete: Cascade)

  @@index([historicSaleId])
  @@index([productName])
  @@map("historic_sale_items")
}